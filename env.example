# Cloud Storage API Keys
# Replace these with your actual API keys from Dropbox and Google Cloud Console

# Dropbox App Configuration
NEXT_PUBLIC_DROPBOX_CLIENT_ID=your_dropbox_app_key_here
NEXT_PUBLIC_DROPBOX_REDIRECT_URI=http://localhost:3000/auth/dropbox/callback

# Google Drive API Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Optional: Server-side API keys (if implementing backend processing)
DROPBOX_APP_SECRET=your_dropbox_app_secret_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# File Processing Configuration
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp,audio/mpeg,audio/wav,audio/ogg,audio/flac

# Application Settings
NEXT_PUBLIC_APP_NAME=Lux Convert
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SUPPORT_EMAIL=support@luxconvert.com

# Analytics and Monitoring (Optional)
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here
SENTRY_DSN=your_sentry_dsn_here
